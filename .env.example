# Kit API credentials. Use fake values in public docs.
KIT_API_KEY=replace-with-your-kit-api-key

# Optional API and request settings.
KIT_BASE_URL=https://api.kit.com/v4
KIT_TIMEOUT=30

# Optional broadcast defaults. Override on the CLI when needed.
KIT_DEFAULT_EMAIL_ADDRESS="Example Sender <newsletter@example.com>"
KIT_DEFAULT_EMAIL_TEMPLATE_ID=123456

# Live tests are opt-in and should use throwaway data.
KIT_ENABLE_LIVE_TESTS=0
KIT_LIVE_TEST_TAG_ID=123456
KIT_LIVE_TEST_EMAIL=alice@example.com
